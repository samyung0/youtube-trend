# === Go Backend (backend/.env or system env) ===

# Required
DATABASE_URL=postgres://user:pass@your-hetzner-ip:5432/thumbtrend
JWT_SECRET=some-random-secret-at-least-32-chars

# YouTube Data API v3 (Google Cloud Console)
YOUTUBE_API_KEY=your-youtube-api-key

# DeepSeek (for topic clustering — https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Google OAuth2 (Google Cloud Console > Credentials > OAuth 2.0)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/callback

# Optional (defaults shown)
# PORT=8080
# FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000

# === Next.js Frontend (.env.local) ===

# Points frontend API calls to Go backend
NEXT_PUBLIC_API_URL=http://localhost:8080
